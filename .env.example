# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# `claude-gateway setup` generates a strong value automatically.
LITELLM_MASTER_KEY=

# Optional launcher settings. Defaults are shown.
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=4000
GATEWAY_MODEL=gemini-3.1-flash-lite
GATEWAY_SMALL_MODEL=gemini-3.1-flash-lite
# GATEWAY_CONFIG=config.yaml
